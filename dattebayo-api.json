{
  "info": {
    "name": "Dattebayo API - Naruto Universe",
    "description": "Complete API collection for accessing Naruto universe data including characters, clans, villages, kekkei-genkai, tailed beasts, teams, Akatsuki, and Kara.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://dattebayo-api.onrender.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Characters",
      "item": [
        {
          "name": "Get All Characters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/characters?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["characters"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Current page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of items per page"
                },
                {
                  "key": "name",
                  "value": "",
                  "description": "Filter by character name (optional)",
                  "disabled": true
                }
              ]
            },
            "description": "Retrieve paginated list of all characters from Naruto universe"
          }
        },
        {
          "name": "Get Characters by IDs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/characters/1,2,3",
              "host": ["{{baseUrl}}"],
              "path": ["characters", "1,2,3"]
            },
            "description": "Retrieve specific characters by their IDs (comma-separated)"
          }
        },
        {
          "name": "Search Characters by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/characters?name=Naruto",
              "host": ["{{baseUrl}}"],
              "path": ["characters"],
              "query": [
                {
                  "key": "name",
                  "value": "Naruto",
                  "description": "Search character by name"
                }
              ]
            },
            "description": "Search for characters by name"
          }
        }
      ]
    },
